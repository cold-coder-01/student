<?xml version="1.0" encoding="utf-8"?>
<odoo>
     <record id="student_form_view" model="ir.ui.view">
        <field name="name">student.form</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <form>
               <sheet>
                  <group>
                     <field name="name"/>
                     <field name="age"/>
                  </group>
               </sheet>
            </form>
        </field>
     </record>
</odoo>